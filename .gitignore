# ================================
# n8n Docker Workflow — .gitignore
# ================================

# ─── n8n Data & Database ───
n8n_data/*
!n8n_data/.gitkeep
database.sqlite
database.sqlite-shm
database.sqlite-wal
crash.journal
n8nEventLog.log
storage/
nodes/
config

# ─── Credentials & Secrets ───
*.credentials
credentials.json
.env
.env.local
.env.production
secrets.json
ngrok.yml
ngrok-authtoken.txt

# ─── Docker ───
docker-compose.override.yml
.docker/

# ─── OS Files ───
.DS_Store
Thumbs.db
desktop.ini

# ─── Node / NPM ───
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Logs ───
*.log
logs/

# ─── IDE / Editor ───
.vscode/
.idea/
*.suo
*.user

# ─── Temp Files ───
*.tmp
*.temp
*.swp